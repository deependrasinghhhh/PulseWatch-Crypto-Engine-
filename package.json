{
  "name": "pulsewatch",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @pulsewatch/api run dev",
    "dev:web": "pnpm --filter @pulsewatch/web run dev",
    "dev:ingestion": "pnpm --filter @pulsewatch/api run dev:ingestion",
    "dev:worker": "pnpm --filter @pulsewatch/api run dev:worker",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "db:migrate": "pnpm --filter @pulsewatch/api run db:migrate",
    "db:seed": "pnpm --filter @pulsewatch/api run db:seed"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
