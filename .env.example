# ══════════════════════════════════════════════════════════════
# PulseWatch — Environment Variables
# Copy to .env and fill in values. Never commit .env itself.
# ══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/pulsewatch

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string

# ── Anthropic (AI Insights) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# ── Email (optional, Phase 2) ────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=
